DEEPSEEK_API_KEY=your_deepseek_api_key_here

# === AI 助教 DeepSeek 配置 ===
# 如果官方 API (https://api.deepseek.com) 网络超时或无法访问，可尝试以下解决方案：

# 1. 使用中转/第三方 API 端点（如 SiliconFlow、OpenRouter 或自定义反代）
# DEEPSEEK_BASE_URL=https://api.example.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# 2. 设置网络代理（后端会自动读取并应用代理）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 3. 设置 API 请求超时时间（单位：秒，默认 60）
# DEEPSEEK_TIMEOUT=120.0
